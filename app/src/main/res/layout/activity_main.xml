<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#E91E63">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hoa Online 24h"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCartCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gio hang (0)"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:padding="4dp" />

    </LinearLayout>

    <!-- Category Filter -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/categoryContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <Button
                android:id="@+id/btnAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tat ca"
                android:layout_marginRight="8dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <Button
                android:id="@+id/btnHoaBo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoa Bó"
                android:layout_marginRight="8dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <Button
                android:id="@+id/btnHoaSinhNhat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoa Sinh Nhật"
                android:layout_marginRight="8dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <Button
                android:id="@+id/btnHoaKhaiTruong"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoa Khai Trương"
                android:layout_marginRight="8dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <Button
                android:id="@+id/btnHoaChiaBuon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoa Chia Buồn"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Products Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</LinearLayout>