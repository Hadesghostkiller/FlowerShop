<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Nút quay lại -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_margin="20dp"
        android:src="@android:drawable/ic_menu_revert"
        android:padding="4dp"
        app:tint="#D81B60"
        android:background="@drawable/bg_ripple"
        android:clickable="true"
        android:focusable="true"/>

    <!-- Lottie Icon -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieLock"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp"
        app:lottie_rawRes="@raw/flower"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Khôi phục mật khẩu"
        android:textSize="24sp"
        android:fontFamily="@font/poppins_regular"
        android:textStyle="bold"
        android:textColor="#D81B60"
        android:layout_below="@id/lottieLock"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/tvSubTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nhập email để nhận liên kết đặt lại mật khẩu"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_regular"
        android:textColor="#666666"
        android:layout_below="@id/tvTitle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="4dp"
        android:paddingHorizontal="40dp"
        android:gravity="center"/>

    <!-- Card chứa Form -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="24dp"
        android:layout_below="@id/tvSubTitle"
        android:layout_marginTop="30dp"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/bg_card">

        <EditText
            android:id="@+id/etForgotEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Nhập Email của bạn"
            android:inputType="textEmailAddress"
            android:fontFamily="@font/poppins_regular"
            android:textColorHint="#888888"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_edittext"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnResetPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Gửi yêu cầu"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_regular"
            android:textStyle="bold"
            android:background="@drawable/bg_button"
            app:backgroundTint="#C2185B"/>

    </LinearLayout>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        <com.airbnb.lottie.LottieAnimationView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/loading_animation" />
    </FrameLayout>

</RelativeLayout>